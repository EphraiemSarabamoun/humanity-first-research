---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { isModelTag } from '../../model-tag';

const slugify = (t: string) => t.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const cleanSlug = (id: string) => id.replace(/\/index$/, '');

export async function getStaticPaths() {
  const posts = await getCollection('research', ({ data }) => !data.draft);
  const cards = await getCollection('models');
  const slug = (t: string) => t.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  const byTag = new Map<string, { tag: string; posts: typeof posts }>();
  for (const p of posts) {
    for (const t of p.data.tags) {
      const s = slug(t);
      if (!byTag.has(s)) byTag.set(s, { tag: t, posts: [] });
      byTag.get(s)!.posts.push(p);
    }
  }
  return [...byTag.entries()].map(([s, { tag, posts }]) => {
    // Versioning is enforced: a model tag with no model card fails the build,
    // so a paper can never ship under a researcher version that has no record
    // of what that version's setup was.
    let card = undefined;
    if (isModelTag(tag)) {
      card = cards.find((c) => slug(c.data.version) === s);
      if (!card) {
        throw new Error(
          `Model tag "${tag}" has no model card. Add src/content/models/${s}.md ` +
            `describing that researcher version's setup before publishing papers under it.`
        );
      }
    }
    return { params: { tag: s }, props: { tag, posts, card } };
  });
}

const { tag, posts, card } = Astro.props;
const sorted = [...posts].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const model = isModelTag(tag);
const Card = card ? (await render(card)).Content : null;
const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
---
<Base
  title={model ? `Model: ${tag}` : `Topic: ${tag}`}
  description={model && card ? card.data.summary : `Research tagged ${tag}.`}
>
  <div class="measure" style="padding-top:2rem;">
    <p class="kicker"><a href="/tags/">Topics</a></p>
    <h1>{tag}</h1>
    {model && card && (
      <>
        <p class="lede">{card.data.summary}</p>
        <dl class="model-facts">
          <div><dt>Status</dt><dd>{card.data.retired ? `retired ${fmtDate(card.data.retired)}` : 'active'}</dd></div>
          <div><dt>Introduced</dt><dd>{fmtDate(card.data.introduced)}</dd></div>
          <div><dt>Base model</dt><dd>{card.data.base_model}</dd></div>
          <div><dt>Harness</dt><dd>{card.data.harness}</dd></div>
        </dl>
        {Card && <div class="essay model-card"><Card /></div>}
        <h2>Papers from this version</h2>
      </>
    )}
    <ul class="feed">
      {sorted.map((p) => (
        <PostCard
          href={`/research/${cleanSlug(p.id)}/`}
          title={p.data.title}
          date={p.data.date}
          summary={p.data.summary}
          tags={p.data.tags}
          oversight={p.data.oversight}
        />
      ))}
    </ul>
  </div>
</Base>
