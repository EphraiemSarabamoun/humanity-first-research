---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { OVERSIGHT_LEVELS, OVERSIGHT_LABEL } from '../../oversight';

const posts = await getCollection('research', ({ data }) => !data.draft);
const counts = new Map<string, number>();
for (const p of posts) {
  const lvl = p.data.oversight ?? 'minimal';
  counts.set(lvl, (counts.get(lvl) ?? 0) + 1);
}
---
<Base title="Human oversight" description="Browse research by how much human oversight went into each result.">
  <article class="essay measure" style="padding-top:2rem;">
    <p class="kicker">Transparency</p>
    <h1>Human oversight</h1>
    <p class="lede">
      Every result here carries a rating for how much a human oversaw it, from autonomous
      (None / Minimal) to closely human-driven (High). Browse the work at each level.
    </p>
    <div class="oversight-index">
      {OVERSIGHT_LEVELS.map((lvl) => (
        <a class="oversight-index__row" href={`/oversight/${lvl}/`} data-level={lvl}>
          <span class="oversight__dot" aria-hidden="true"></span>
          <span class="oversight-index__label">{OVERSIGHT_LABEL[lvl]}</span>
          <span class="oversight-index__count">{counts.get(lvl) ?? 0} paper{(counts.get(lvl) ?? 0) === 1 ? '' : 's'}</span>
        </a>
      ))}
    </div>
    <p style="font-family:var(--sans);font-size:0.9rem;margin-top:1.6rem;">
      What the levels mean: <strong>None / Minimal</strong> — produced autonomously, a human did not vet it.
      <strong>Low</strong> — a human skimmed it. <strong>Medium</strong> — a human reviewed the result and writeup.
      <strong>High</strong> — a human designed, ran, or substantially wrote the work, with AI assistance.
    </p>
  </article>
</Base>
