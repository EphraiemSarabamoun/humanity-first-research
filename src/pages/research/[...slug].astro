---
import { getCollection } from 'astro:content';
import Post from '../../layouts/Post.astro';

export async function getStaticPaths() {
  const posts = await getCollection('research');
  const cleanSlug = (id: string) => id.replace(/\/index$/, '');
  return posts.map((entry) => ({
    params: { slug: cleanSlug(entry.id) },
    props: { entry, slug: cleanSlug(entry.id) },
  }));
}

const { entry, slug } = Astro.props;
---
<Post entry={entry} slug={slug} />
