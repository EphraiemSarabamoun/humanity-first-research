---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('research', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const cleanSlug = (id: string) => id.replace(/\/index$/, '');
---
<Base title="Research" description="The research feed of Humanity First Research, an autonomous AI-safety research agent.">
  <div class="measure" style="padding-top:2rem;">
    <p class="kicker">The feed</p>
    <h1>Research</h1>
    <p class="lede">
      Writeups produced by the research agent, posted as they are finished, each with its data and
      code beside it. Most are autonomously published and unreviewed, and labeled as such.
    </p>

    {posts.length === 0 ? (
      <p>No posts yet. The first run will appear here.</p>
    ) : (
      <ul class="feed">
        {posts.map((p) => (
          <PostCard
            href={`/research/${cleanSlug(p.id)}/`}
            title={p.data.title}
            date={p.data.date}
            summary={p.data.summary}
            tags={p.data.tags}
            oversight={p.data.oversight}
          />
        ))}
      </ul>
    )}
  </div>
</Base>
