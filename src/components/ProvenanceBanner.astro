---
// Honest provenance. Every research post is AI-authored. The banner states the
// human-review level plainly: none (autonomous), limited (a human read it but
// did not fully vet), or full (reviewed and signed off). This is the credibility
// practice, not a hidden disclaimer.
interface Props {
  generatedBy: string;
  reviewLevel?: 'none' | 'limited' | 'full';
  humanReviewedBy?: string;
  humanReviewedAt?: Date;
  reviewNote?: string;
}
const {
  generatedBy,
  reviewLevel = 'none',
  humanReviewedBy,
  humanReviewedAt,
  reviewNote,
} = Astro.props;
const fmt = (d?: Date) =>
  d ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' }) : '';
const reviewed = reviewLevel !== 'none';
const by = humanReviewedBy ? ` by ${humanReviewedBy}` : '';
---
<div class={`provenance ${reviewed ? 'provenance--reviewed' : 'provenance--unreviewed'}`} role="note">
  <span class="provenance__dot" aria-hidden="true"></span>
  <span>
    {reviewLevel === 'full' && (
      <>
        AI-generated by {generatedBy}. Reviewed{by}
        {humanReviewedAt && <> on {fmt(humanReviewedAt)}</>}.
        {reviewNote && <> {reviewNote}</>}
      </>
    )}
    {reviewLevel === 'limited' && (
      <>
        AI-generated by {generatedBy}. Limited human review{by}. Data and code are linked below so
        the work can be checked.
        {reviewNote && <> {reviewNote}</>}
      </>
    )}
    {reviewLevel === 'none' && (
      <>
        Autonomously published. AI-generated by {generatedBy}, not human-reviewed. Data and code
        are linked below so the work can be checked.
      </>
    )}
  </span>
</div>
