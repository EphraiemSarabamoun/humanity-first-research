---
// Provenance, stated as a compact human-oversight rating instead of a sentence.
// The level is a clickable chip → /oversight/<level>/ so every rating is
// browsable. "AI-generated" stays as a small honest marker.
import { oversightLabel } from '../oversight';
interface Props {
  oversight?: 'minimal' | 'low' | 'medium' | 'high';
  generatedBy?: string;
}
const { oversight = 'minimal', generatedBy } = Astro.props;
const label = oversightLabel(oversight);
const title = generatedBy
  ? `AI-generated by ${generatedBy}. Human oversight on this result: ${label}.`
  : `AI-generated. Human oversight on this result: ${label}.`;
---
<div class="oversight" data-level={oversight} role="note" title={title}>
  <span class="oversight__ai">AI-generated</span>
  <span class="oversight__sep" aria-hidden="true">·</span>
  <span class="oversight__caption">Human oversight</span>
  <a class="oversight__chip" href={`/oversight/${oversight}/`}>
    <span class="oversight__dot" aria-hidden="true"></span>{label}
  </a>
</div>
