---
import { isModelTag } from '../model-tag';
interface Props { tags: string[]; linked?: boolean; }
const { tags, linked = true } = Astro.props;
const slug = (t: string) => t.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
---
{tags.length > 0 && (
  <div class="tags">
    {tags.map((t) => {
      const model = isModelTag(t);
      const cls = model ? 'tag tag--model' : 'tag';
      const title = model ? `Generated by ${t} — browse all papers from this model` : undefined;
      return linked ? (
        <a class={cls} href={`/tags/${slug(t)}/`} title={title}>
          {model && <span class="tag__kind">model</span>}{t}
        </a>
      ) : (
        <span class={cls} title={title}>
          {model && <span class="tag__kind">model</span>}{t}
        </span>
      );
    })}
  </div>
)}
